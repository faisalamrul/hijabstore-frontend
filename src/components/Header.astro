---
import { url } from '../lib/url';

const navLinks = [
  { label: 'Produk', href: url('/products') },
  { label: 'Magazine', href: url('/magazine') },
  { label: 'Tentang', href: url('/tentang') },
];
---

<header class="sticky top-0 z-50 border-b border-neutral-200 bg-white/95 backdrop-blur-sm">
  <div class="mx-auto flex h-16 max-w-7xl items-center justify-between px-4 sm:px-6 lg:px-8">
    <!-- Logo -->
    <a href={url('/')} class="text-lg font-light tracking-[0.3em] uppercase text-neutral-950">
      Hara
    </a>

    <!-- Desktop nav -->
    <nav class="hidden sm:flex items-center gap-8">
      {navLinks.map((link) => (
        <a
          href={link.href}
          class="text-xs tracking-widest uppercase text-neutral-600 transition-colors hover:text-neutral-950"
        >
          {link.label}
        </a>
      ))}
    </nav>

    <!-- Hamburger button (mobile only) -->
    <button
      id="menu-toggle"
      aria-label="Buka menu"
      aria-expanded="false"
      class="sm:hidden flex h-10 w-10 items-center justify-center text-neutral-700"
    >
      <!-- Hamburger icon -->
      <svg id="icon-open" xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
        <path stroke-linecap="round" stroke-linejoin="round" d="M4 6h16M4 12h16M4 18h16" />
      </svg>
      <!-- Close icon -->
      <svg id="icon-close" xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 hidden" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
        <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12" />
      </svg>
    </button>
  </div>

  <!-- Mobile menu drawer -->
  <div
    id="mobile-menu"
    class="hidden sm:hidden border-t border-neutral-100 bg-white px-4 pb-6 pt-4"
  >
    <nav class="flex flex-col gap-1">
      {navLinks.map((link) => (
        <a
          href={link.href}
          class="block py-3 text-xs tracking-widest uppercase text-neutral-600 border-b border-neutral-100 last:border-0 hover:text-neutral-950 transition-colors"
        >
          {link.label}
        </a>
      ))}
    </nav>
  </div>
</header>

<script>
  const toggle = document.getElementById('menu-toggle')!;
  const menu = document.getElementById('mobile-menu')!;
  const iconOpen = document.getElementById('icon-open')!;
  const iconClose = document.getElementById('icon-close')!;

  toggle.addEventListener('click', () => {
    const isOpen = !menu.classList.contains('hidden');
    menu.classList.toggle('hidden', isOpen);
    iconOpen.classList.toggle('hidden', !isOpen);
    iconClose.classList.toggle('hidden', isOpen);
    toggle.setAttribute('aria-expanded', String(!isOpen));
  });

  // Close menu when a link is tapped
  menu.querySelectorAll('a').forEach((a) => {
    a.addEventListener('click', () => {
      menu.classList.add('hidden');
      iconOpen.classList.remove('hidden');
      iconClose.classList.add('hidden');
      toggle.setAttribute('aria-expanded', 'false');
    });
  });
</script>
