---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { posts, getPostBySlug } from '../../data/posts';
import type { Post } from '../../types/post';
import { url } from '../../lib/url';

export function getStaticPaths() {
  return posts.map((p) => ({ params: { slug: p.slug } }));
}

const { slug } = Astro.params;
const post = getPostBySlug(slug);
if (!post) return Astro.redirect(url('/magazine'));

const related = posts
  .filter((p) => p.category === post.category && p.id !== post.id)
  .slice(0, 3);

function formatDate(iso: string): string {
  return new Date(iso).toLocaleDateString('id-ID', {
    day: 'numeric',
    month: 'long',
    year: 'numeric',
  });
}

function renderContent(raw: string): string {
  return raw
    .trim()
    .split('\n\n')
    .map((block) => {
      const trimmed = block.trim();
      if (trimmed.startsWith('## ')) {
        return `<h2>${trimmed.slice(3)}</h2>`;
      }
      const withBold = trimmed.replace(/\*\*(.+?)\*\*/g, '<strong>$1</strong>');
      return `<p>${withBold}</p>`;
    })
    .join('\n');
}

const htmlContent = renderContent(post.content);

const siteUrl = 'https://faisalamrul.github.io/hijabstore-frontend';
const articleSchema = {
  '@context': 'https://schema.org',
  '@type': 'Article',
  headline: post.title,
  description: post.excerpt,
  image: post.image,
  author: {
    '@type': 'Person',
    name: 'Tim Editorial Hara',
    jobTitle: 'Fashion Editor',
    worksFor: { '@type': 'Organization', name: 'Hara' },
  },
  publisher: {
    '@type': 'Organization',
    name: 'Hara',
    logo: { '@type': 'ImageObject', url: `${siteUrl}/favicon.svg` },
  },
  datePublished: post.publishedAt,
  url: `${siteUrl}/magazine/${post.slug}`,
};

const faqSchema = post.faqs
  ? {
      '@context': 'https://schema.org',
      '@type': 'FAQPage',
      mainEntity: post.faqs.map((faq) => ({
        '@type': 'Question',
        name: faq.question,
        acceptedAnswer: { '@type': 'Answer', text: faq.answer },
      })),
    }
  : null;

const breadcrumbSchema = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Home', item: siteUrl },
    { '@type': 'ListItem', position: 2, name: 'Magazine', item: `${siteUrl}/magazine` },
    { '@type': 'ListItem', position: 3, name: post.title, item: `${siteUrl}/magazine/${post.slug}` },
  ],
};
---

<BaseLayout title={post.title} description={post.excerpt} ogImage={post.image} ogType="article">
  <Fragment slot="head">
    <script type="application/ld+json" set:html={JSON.stringify(articleSchema)} />
    <script type="application/ld+json" set:html={JSON.stringify(breadcrumbSchema)} />
    {faqSchema && <script type="application/ld+json" set:html={JSON.stringify(faqSchema)} />}
  </Fragment>
  <!-- Breadcrumb -->
  <div class="mx-auto max-w-7xl px-4 pt-6 pb-2 sm:px-6 lg:px-8">
    <nav class="flex items-center gap-2 text-[10px] tracking-widest uppercase text-neutral-400">
      <a href={url('/')} class="hover:text-neutral-950 transition-colors">Home</a>
      <span>/</span>
      <a href={url('/magazine')} class="hover:text-neutral-950 transition-colors">Magazine</a>
      <span>/</span>
      <span class="text-neutral-950 truncate max-w-[180px]">{post.category}</span>
    </nav>
  </div>

  <!-- Two-column layout -->
  <div class="mx-auto max-w-7xl px-4 py-8 sm:px-6 lg:px-8 lg:py-12">
    <div class="grid grid-cols-1 gap-10 lg:grid-cols-[5fr_7fr] lg:gap-16 lg:items-start">

      <!-- LEFT: Image — sticky on desktop -->
      <div class="lg:sticky lg:top-24">
        <div class="overflow-hidden bg-neutral-100 aspect-[4/5] w-full">
          <img
            src={post.image}
            alt={post.title}
            class="h-full w-full object-cover"
            loading="eager"
          />
        </div>
        <!-- Caption / category pill under image -->
        <div class="mt-4 flex items-center gap-3">
          <span class="text-[9px] tracking-[0.35em] uppercase border border-neutral-950 px-2.5 py-1 text-neutral-950">
            {post.category}
          </span>
          <span class="text-[10px] tracking-widest uppercase text-neutral-400">
            {post.readTime} min read
          </span>
        </div>
      </div>

      <!-- RIGHT: Article content -->
      <article class="min-w-0">
        <!-- Meta -->
        <p class="text-[10px] tracking-[0.4em] uppercase text-neutral-400 mb-4">
          {formatDate(post.publishedAt)}
        </p>

        <!-- Title -->
        <h1 class="text-2xl sm:text-3xl lg:text-4xl font-light tracking-wide text-neutral-950 leading-snug mb-6">
          {post.title}
        </h1>

        <!-- Excerpt / lead -->
        <p class="text-base text-neutral-600 leading-relaxed border-l-2 border-neutral-200 pl-5 mb-8 italic">
          {post.excerpt}
        </p>

        <!-- Author -->
        <div class="flex items-center gap-3 mb-8 pb-8 border-b border-neutral-100">
          <div class="h-8 w-8 rounded-full bg-neutral-950 flex items-center justify-center shrink-0">
            <span class="text-[10px] font-medium text-white">H</span>
          </div>
          <div>
            <p class="text-xs font-medium text-neutral-950">{post.author}</p>
            <p class="text-[10px] text-neutral-400 tracking-widest uppercase">Hara Magazine</p>
          </div>
        </div>

        <!-- Body -->
        <div class="prose-hara" set:html={htmlContent} />

        <!-- FAQ Section -->
        {post.faqs && (
          <div class="mt-12 pt-10 border-t border-neutral-100">
            <p class="text-[9px] tracking-[0.4em] uppercase text-neutral-400 mb-2">FAQ</p>
            <h2 class="text-lg font-light tracking-wide text-neutral-950 mb-8">
              Pertanyaan yang Sering Ditanyakan
            </h2>
            <dl class="space-y-6">
              {post.faqs.map((faq) => (
                <div class="border-b border-neutral-100 pb-6">
                  <dt class="text-sm font-medium text-neutral-950 mb-2">{faq.question}</dt>
                  <dd class="text-sm text-neutral-500 leading-relaxed">{faq.answer}</dd>
                </div>
              ))}
            </dl>
          </div>
        )}

        <!-- Back link -->
        <div class="mt-12 pt-8 border-t border-neutral-100">
          <a
            href={url('/magazine')}
            class="text-xs tracking-widest uppercase text-neutral-600 border-b border-neutral-300 pb-0.5 hover:text-neutral-950 hover:border-neutral-950 transition-colors"
          >
            ← Kembali ke Magazine
          </a>
        </div>
      </article>

    </div>
  </div>

  <!-- Related articles -->
  {related.length > 0 && (
    <section class="border-t border-neutral-100 bg-stone-50 py-16">
      <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
        <div class="mb-10 text-center">
          <p class="text-[10px] tracking-[0.4em] uppercase text-neutral-400 mb-2">Baca Juga</p>
          <h2 class="text-xl font-light tracking-[0.2em] uppercase text-neutral-950">
            Artikel Lainnya
          </h2>
        </div>
        <div class="grid grid-cols-1 gap-8 sm:grid-cols-3">
          {related.map((p) => (
            <a href={url(`/magazine/${p.slug}`)} class="group block">
              <div class="overflow-hidden bg-neutral-100 aspect-[3/2] mb-4">
                <img
                  src={p.image}
                  alt={p.title}
                  class="h-full w-full object-cover transition-transform duration-500 group-hover:scale-105"
                  loading="lazy"
                />
              </div>
              <span class="text-[9px] tracking-[0.3em] uppercase text-neutral-400 border border-neutral-200 px-2 py-0.5">
                {p.category}
              </span>
              <h3 class="mt-3 text-sm font-medium text-neutral-950 leading-snug group-hover:text-neutral-500 transition-colors">
                {p.title}
              </h3>
              <p class="mt-2 text-[10px] tracking-widest uppercase text-neutral-400">
                {formatDate(p.publishedAt)}
              </p>
            </a>
          ))}
        </div>
      </div>
    </section>
  )}
</BaseLayout>

<style>
  .prose-hara :global(h2) {
    font-size: 1.125rem;
    font-weight: 500;
    letter-spacing: 0.025em;
    color: #0a0a0a;
    margin-top: 2.5rem;
    margin-bottom: 1rem;
    padding-bottom: 0.5rem;
    border-bottom: 1px solid #e5e5e5;
  }
  .prose-hara :global(p) {
    font-size: 0.9375rem;
    line-height: 1.8;
    color: #525252;
    margin-bottom: 1.25rem;
  }
  .prose-hara :global(strong) {
    font-weight: 600;
    color: #171717;
  }
</style>
