---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { posts, getPostBySlug } from '../../data/posts';
import type { Post } from '../../types/post';
import { url } from '../../lib/url';

export function getStaticPaths() {
  return posts.map((p) => ({ params: { slug: p.slug } }));
}

const { slug } = Astro.params;
const post = getPostBySlug(slug);
if (!post) return Astro.redirect(url('/magazine'));

const related = posts
  .filter((p) => p.category === post.category && p.id !== post.id)
  .slice(0, 3);

function formatDate(iso: string): string {
  return new Date(iso).toLocaleDateString('id-ID', {
    day: 'numeric',
    month: 'long',
    year: 'numeric',
  });
}

const categoryColors: Record<Post['category'], string> = {
  Style: 'border-neutral-950 text-neutral-950',
  Tutorial: 'border-neutral-950 text-neutral-950',
  Trend: 'border-neutral-950 text-neutral-950',
  Tips: 'border-neutral-950 text-neutral-950',
};

// Simple markdown-like parser: ## → h2, **text** → bold, paragraph breaks
function renderContent(raw: string): string {
  return raw
    .trim()
    .split('\n\n')
    .map((block) => {
      const trimmed = block.trim();
      if (trimmed.startsWith('## ')) {
        return `<h2>${trimmed.slice(3)}</h2>`;
      }
      const withBold = trimmed.replace(/\*\*(.+?)\*\*/g, '<strong>$1</strong>');
      return `<p>${withBold}</p>`;
    })
    .join('\n');
}

const htmlContent = renderContent(post.content);
---

<BaseLayout title={post.title} description={post.excerpt}>
  <!-- Hero image -->
  <div class="w-full bg-neutral-100 aspect-[16/7] overflow-hidden">
    <img
      src={post.image}
      alt={post.title}
      class="h-full w-full object-cover"
      loading="eager"
    />
  </div>

  <!-- Article -->
  <article class="mx-auto max-w-2xl px-4 py-14 sm:px-6">
    <!-- Breadcrumb -->
    <nav class="mb-8 flex items-center gap-2 text-[10px] tracking-widest uppercase text-neutral-400">
      <a href={url('/')} class="hover:text-neutral-950 transition-colors">Home</a>
      <span>/</span>
      <a href={url('/magazine')} class="hover:text-neutral-950 transition-colors">Magazine</a>
      <span>/</span>
      <span class="text-neutral-950 truncate max-w-[180px]">{post.category}</span>
    </nav>

    <!-- Category + meta -->
    <div class="flex flex-wrap items-center gap-3 mb-6">
      <span class={`text-[9px] tracking-[0.3em] uppercase border px-2.5 py-1 ${categoryColors[post.category]}`}>
        {post.category}
      </span>
      <span class="text-[10px] tracking-widest uppercase text-neutral-400">
        {formatDate(post.publishedAt)}
      </span>
      <span class="text-neutral-300">·</span>
      <span class="text-[10px] tracking-widest uppercase text-neutral-400">
        {post.readTime} min read
      </span>
    </div>

    <!-- Title -->
    <h1 class="text-3xl sm:text-4xl font-light tracking-wide text-neutral-950 leading-tight mb-6">
      {post.title}
    </h1>

    <!-- Excerpt / lead -->
    <p class="text-base text-neutral-600 leading-relaxed border-l-2 border-neutral-200 pl-5 mb-10 italic">
      {post.excerpt}
    </p>

    <!-- Author -->
    <div class="flex items-center gap-3 mb-10 pb-10 border-b border-neutral-100">
      <div class="h-8 w-8 rounded-full bg-neutral-950 flex items-center justify-center">
        <span class="text-[10px] font-medium text-white">H</span>
      </div>
      <div>
        <p class="text-xs font-medium text-neutral-950">{post.author}</p>
        <p class="text-[10px] text-neutral-400 tracking-widest uppercase">Hara Magazine</p>
      </div>
    </div>

    <!-- Body content -->
    <div
      class="prose-hara"
      set:html={htmlContent}
    />

    <!-- Divider -->
    <div class="mt-14 pt-10 border-t border-neutral-100">
      <a
        href={url('/magazine')}
        class="text-xs tracking-widest uppercase text-neutral-600 border-b border-neutral-300 pb-0.5 hover:text-neutral-950 hover:border-neutral-950 transition-colors"
      >
        ← Kembali ke Magazine
      </a>
    </div>
  </article>

  <!-- Related articles -->
  {related.length > 0 && (
    <section class="border-t border-neutral-100 bg-stone-50 py-16">
      <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
        <div class="mb-10 text-center">
          <p class="text-[10px] tracking-[0.4em] uppercase text-neutral-400 mb-2">Baca Juga</p>
          <h2 class="text-xl font-light tracking-[0.2em] uppercase text-neutral-950">
            Artikel Lainnya
          </h2>
        </div>
        <div class="grid grid-cols-1 gap-8 sm:grid-cols-3">
          {related.map((p) => (
            <a href={url(`/magazine/${p.slug}`)} class="group block">
              <div class="overflow-hidden bg-neutral-100 aspect-[3/2] mb-4">
                <img
                  src={p.image}
                  alt={p.title}
                  class="h-full w-full object-cover transition-transform duration-500 group-hover:scale-105"
                  loading="lazy"
                />
              </div>
              <span class="text-[9px] tracking-[0.3em] uppercase text-neutral-400 border border-neutral-200 px-2 py-0.5">
                {p.category}
              </span>
              <h3 class="mt-3 text-sm font-medium text-neutral-950 leading-snug group-hover:text-neutral-500 transition-colors">
                {p.title}
              </h3>
              <p class="mt-2 text-[10px] tracking-widest uppercase text-neutral-400">
                {formatDate(p.publishedAt)}
              </p>
            </a>
          ))}
        </div>
      </div>
    </section>
  )}
</BaseLayout>

<style>
  .prose-hara :global(h2) {
    font-size: 1.125rem;
    font-weight: 500;
    letter-spacing: 0.025em;
    color: #0a0a0a;
    margin-top: 2.5rem;
    margin-bottom: 1rem;
    padding-bottom: 0.5rem;
    border-bottom: 1px solid #e5e5e5;
  }
  .prose-hara :global(p) {
    font-size: 0.9375rem;
    line-height: 1.8;
    color: #525252;
    margin-bottom: 1.25rem;
  }
  .prose-hara :global(strong) {
    font-weight: 600;
    color: #171717;
  }
</style>
