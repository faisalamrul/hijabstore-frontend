---
import BaseLayout from '../layouts/BaseLayout.astro';
import { url } from '../lib/url';

const siteUrl = 'https://faisalamrul.github.io/hijabstore-frontend';

const contactFaqs = [
  {
    q: 'Berapa lama waktu pengiriman?',
    a: 'Pengiriman dalam kota biasanya 1–2 hari kerja. Pengiriman ke luar kota 2–4 hari kerja menggunakan JNE, SiCepat, atau J&T sesuai pilihan. Kami memproses pesanan dalam 1 hari kerja setelah pembayaran dikonfirmasi.',
  },
  {
    q: 'Apakah bisa retur atau tukar ukuran?',
    a: 'Ya, kami menerima retur dan tukar ukuran dalam 7 hari setelah penerimaan produk, dengan syarat produk belum dipakai, label masih terpasang, dan dikemas dalam kondisi semula. Hubungi kami via WhatsApp untuk proses penukaran.',
  },
  {
    q: 'Metode pembayaran apa yang diterima?',
    a: 'Kami menerima transfer bank (BCA, BRI, Mandiri, BNI), dompet digital (GoPay, OVO, DANA, ShopeePay), dan COD untuk area tertentu. Pembayaran dikonfirmasi dalam 1–2 jam pada jam kerja.',
  },
  {
    q: 'Apakah produk Hara tersedia di marketplace?',
    a: 'Saat ini kami melayani pemesanan langsung via WhatsApp dan website ini untuk memastikan layanan terbaik. Kami sedang dalam proses membuka toko resmi di Tokopedia dan Shopee — pantau terus update kami.',
  },
];
---

<BaseLayout
  title="Hubungi Hara — Layanan Pelanggan Hijab Premium"
  description="Hubungi tim Hara via WhatsApp atau email untuk pertanyaan produk, pesanan, dan layanan pelanggan. Kami siap membantu Senin–Sabtu pukul 09.00–18.00 WIB."
>
  <div class="mx-auto max-w-4xl px-4 py-12 sm:px-6 lg:px-8 lg:py-20">
    <!-- Breadcrumb -->
    <nav class="mb-10 flex items-center gap-2 text-[10px] tracking-widest uppercase text-neutral-400">
      <a href={url('/')} class="hover:text-neutral-950 transition-colors">Home</a>
      <span>/</span>
      <span class="text-neutral-950">Kontak</span>
    </nav>

    <!-- Header -->
    <div class="mb-14">
      <p class="text-[10px] tracking-[0.4em] uppercase text-neutral-400 mb-3">Layanan Pelanggan</p>
      <h1 class="text-3xl sm:text-4xl font-light tracking-wide text-neutral-950 mb-6">
        Hubungi Kami
      </h1>
      <p class="text-base text-neutral-500 leading-relaxed max-w-xl">
        Tim Hara siap membantu pertanyaan seputar produk, pemesanan, pengiriman, dan layanan purna jual. Kami berkomitmen merespons setiap pesan dalam waktu 2 jam pada jam kerja.
      </p>
    </div>

    <!-- Contact options -->
    <div class="grid grid-cols-1 gap-6 sm:grid-cols-2 mb-16">
      <!-- WhatsApp -->
      <a
        href="https://wa.me/6281234567890?text=Halo%20Hara%2C%20saya%20ingin%20bertanya%20tentang%20produk."
        target="_blank"
        rel="noopener noreferrer"
        class="group flex items-start gap-5 border border-neutral-200 p-6 hover:border-neutral-950 transition-colors"
      >
        <div class="shrink-0 w-10 h-10 bg-neutral-950 flex items-center justify-center">
          <svg class="w-5 h-5 text-white" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
            <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
          </svg>
        </div>
        <div>
          <p class="text-sm font-medium text-neutral-950 mb-1 group-hover:underline">WhatsApp</p>
          <p class="text-xs text-neutral-500 mb-2">+62 812-3456-7890</p>
          <p class="text-[10px] tracking-widest uppercase text-neutral-400">Senin–Sabtu · 09.00–18.00 WIB</p>
        </div>
      </a>

      <!-- Email -->
      <div class="flex items-start gap-5 border border-neutral-100 p-6">
        <div class="shrink-0 w-10 h-10 bg-neutral-100 flex items-center justify-center">
          <svg class="w-5 h-5 text-neutral-600" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" d="M21.75 6.75v10.5a2.25 2.25 0 01-2.25 2.25h-15a2.25 2.25 0 01-2.25-2.25V6.75m19.5 0A2.25 2.25 0 0019.5 4.5h-15a2.25 2.25 0 00-2.25 2.25m19.5 0v.243a2.25 2.25 0 01-1.07 1.916l-7.5 4.615a2.25 2.25 0 01-2.36 0L3.32 8.91a2.25 2.25 0 01-1.07-1.916V6.75" />
          </svg>
        </div>
        <div>
          <p class="text-sm font-medium text-neutral-950 mb-1">Email</p>
          <p class="text-xs text-neutral-500 mb-2">hello@harastore.id</p>
          <p class="text-[10px] tracking-widest uppercase text-neutral-400">Respons dalam 1 hari kerja</p>
        </div>
      </div>
    </div>

    <!-- FAQ section -->
    <div class="border-t border-neutral-100 pt-12">
      <p class="text-[10px] tracking-[0.4em] uppercase text-neutral-400 mb-3">FAQ</p>
      <h2 class="text-lg font-light tracking-wide text-neutral-950 mb-8">
        Pertanyaan Umum
      </h2>
      <dl class="space-y-6">
        {contactFaqs.map((faq) => (
          <div class="border-b border-neutral-100 pb-6">
            <dt class="text-sm font-medium text-neutral-950 mb-2">{faq.q}</dt>
            <dd class="text-sm text-neutral-500 leading-relaxed">{faq.a}</dd>
          </div>
        ))}
      </dl>
    </div>

    <!-- CTA to shop -->
    <div class="mt-14 pt-10 border-t border-neutral-100">
      <p class="text-xs text-neutral-400 mb-4">Siap berbelanja?</p>
      <a
        href={url('/products')}
        class="inline-block border border-neutral-950 px-8 py-3 text-xs tracking-[0.3em] uppercase text-neutral-950 hover:bg-neutral-950 hover:text-white transition-all duration-300"
      >
        Lihat Koleksi
      </a>
    </div>
  </div>
</BaseLayout>
