---
import BaseLayout from '../../layouts/BaseLayout.astro';
import ProductCard from '../../components/ProductCard.astro';
import { products } from '../../data/products';

const allProducts = products;
---

<BaseLayout title="Produk" description="Temukan koleksi hijab Hara — Instan, Pashmina, dan Bergo.">
  <div class="mx-auto max-w-7xl px-4 py-16 sm:px-6 lg:px-8">
    <!-- Page header -->
    <div class="mb-10 text-center">
      <p class="text-[10px] tracking-[0.4em] uppercase text-neutral-400 mb-2">Semua Koleksi</p>
      <h1 class="text-3xl font-light tracking-[0.2em] uppercase text-neutral-950">Produk</h1>
    </div>

    <!-- Filter & Sort bar -->
    <div class="mb-8 flex flex-col gap-4 sm:flex-row sm:items-center sm:justify-between">
      <!-- Category filters -->
      <div class="flex flex-wrap gap-2" id="filter-buttons">
        {['Semua', 'Instan', 'Pashmina', 'Bergo'].map((cat) => (
          <button
            data-filter={cat === 'Semua' ? 'all' : cat.toLowerCase()}
            class="filter-btn border border-neutral-200 px-4 py-1.5 text-xs tracking-widest uppercase text-neutral-600 transition-all hover:border-neutral-950 hover:text-neutral-950 data-[active]:bg-neutral-950 data-[active]:text-white data-[active]:border-neutral-950"
          >
            {cat}
          </button>
        ))}
      </div>

      <!-- Sort -->
      <select
        id="sort-select"
        class="border border-neutral-200 px-3 py-1.5 text-xs tracking-widest uppercase text-neutral-600 bg-white focus:outline-none focus:border-neutral-950 cursor-pointer"
      >
        <option value="default">Terbaru</option>
        <option value="price-asc">Harga Terendah</option>
        <option value="price-desc">Harga Tertinggi</option>
      </select>
    </div>

    <!-- Product grid -->
    <div
      id="product-grid"
      class="grid grid-cols-2 gap-4 sm:gap-6 md:grid-cols-3 lg:grid-cols-4"
    >
      {allProducts.map((product) => (
        <div
          class="product-item"
          data-category={product.category}
          data-price={product.price}
          data-index={product.id}
        >
          <ProductCard product={product} />
        </div>
      ))}
    </div>

    <!-- Empty state -->
    <div id="empty-state" class="hidden py-24 text-center">
      <p class="text-sm text-neutral-400 tracking-widest uppercase">Tidak ada produk ditemukan</p>
    </div>
  </div>
</BaseLayout>

<script>
  const filterBtns = document.querySelectorAll<HTMLButtonElement>('.filter-btn');
  const items = document.querySelectorAll<HTMLElement>('.product-item');
  const sortSelect = document.getElementById('sort-select') as HTMLSelectElement;
  const grid = document.getElementById('product-grid')!;
  const emptyState = document.getElementById('empty-state')!;

  let activeFilter = 'all';

  function applyFilter(filter: string) {
    activeFilter = filter;
    filterBtns.forEach((btn) => {
      btn.dataset.active = btn.dataset.filter === filter ? 'true' : undefined;
      if (btn.dataset.filter !== filter) delete btn.dataset.active;
    });
    renderItems();
  }

  function renderItems() {
    const sortVal = sortSelect.value;
    const visible = Array.from(items).filter((item) => {
      return activeFilter === 'all' || item.dataset.category === activeFilter;
    });

    visible.sort((a, b) => {
      const priceA = Number(a.dataset.price);
      const priceB = Number(b.dataset.price);
      if (sortVal === 'price-asc') return priceA - priceB;
      if (sortVal === 'price-desc') return priceB - priceA;
      return Number(a.dataset.index) - Number(b.dataset.index);
    });

    items.forEach((item) => (item.style.display = 'none'));
    visible.forEach((item) => {
      item.style.display = 'block';
      grid.appendChild(item);
    });

    emptyState.classList.toggle('hidden', visible.length > 0);
  }

  filterBtns.forEach((btn) => {
    btn.addEventListener('click', () => applyFilter(btn.dataset.filter ?? 'all'));
  });

  sortSelect.addEventListener('change', renderItems);

  // Set "Semua" as active on load
  applyFilter('all');
</script>
