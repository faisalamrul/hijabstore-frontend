---
import BaseLayout from '../../layouts/BaseLayout.astro';
import ProductCard from '../../components/ProductCard.astro';
import { getProductsByCategory } from '../../data/products';
import { url } from '../../lib/url';

const products = getProductsByCategory('instan');
const siteUrl = 'https://faisalamrul.github.io/hijabstore-frontend';

const collectionSchema = {
  '@context': 'https://schema.org',
  '@type': 'CollectionPage',
  name: 'Hijab Instan Premium — Koleksi Hara',
  description:
    'Koleksi hijab instan premium Hara. Mudah dipakai, nyaman sepanjang hari, tersedia dalam berbagai warna netral dan bahan berkualitas tinggi.',
  url: `${siteUrl}/koleksi/instan`,
  breadcrumb: {
    '@type': 'BreadcrumbList',
    itemListElement: [
      { '@type': 'ListItem', position: 1, name: 'Home', item: siteUrl },
      { '@type': 'ListItem', position: 2, name: 'Koleksi Instan', item: `${siteUrl}/koleksi/instan` },
    ],
  },
  mainEntity: {
    '@type': 'ItemList',
    name: 'Hijab Instan Hara',
    itemListElement: products.map((p, i) => ({
      '@type': 'ListItem',
      position: i + 1,
      name: p.name,
      url: `${siteUrl}/products/${p.slug}`,
      image: p.images[0],
    })),
  },
};
---

<BaseLayout
  title="Hijab Instan Premium — Koleksi Hara"
  description="Koleksi hijab instan premium Hara. Mudah dipakai, nyaman sepanjang hari, tersedia dalam berbagai warna netral dan bahan berkualitas tinggi."
>
  <Fragment slot="head">
    <script type="application/ld+json" set:html={JSON.stringify(collectionSchema)} />
  </Fragment>

  <div class="mx-auto max-w-7xl px-4 py-12 sm:px-6 lg:px-8 lg:py-20">
    <!-- Breadcrumb -->
    <nav class="mb-10 flex items-center gap-2 text-[10px] tracking-widest uppercase text-neutral-400">
      <a href={url('/')} class="hover:text-neutral-950 transition-colors">Home</a>
      <span>/</span>
      <span class="text-neutral-950">Instan</span>
    </nav>

    <!-- Header -->
    <div class="mb-12 max-w-2xl">
      <p class="text-[10px] tracking-[0.4em] uppercase text-neutral-400 mb-3">Koleksi</p>
      <h1 class="text-3xl sm:text-4xl font-light tracking-wide text-neutral-950 mb-6">
        Hijab Instan Premium
      </h1>
      <p class="text-base text-neutral-500 leading-relaxed">
        Hijab instan adalah pilihan terbaik untuk wanita aktif yang menginginkan tampilan rapi tanpa repot. Koleksi instan Hara hadir dalam bahan jersey premium, cotton pima, dan microfiber yang ringan dan breathable — sempurna untuk dipakai dari pagi hingga malam tanpa menyesuaikan ulang. Tersedia dalam palet warna netral yang mudah dipadukan dengan berbagai outfit.
      </p>
    </div>

    <!-- Product Grid -->
    <div class="grid grid-cols-2 gap-4 sm:gap-6 md:grid-cols-3">
      {products.map((product) => <ProductCard product={product} />)}
    </div>

    <!-- Cross-link to magazine -->
    <div class="mt-16 border-t border-neutral-100 pt-10">
      <p class="text-[10px] tracking-[0.4em] uppercase text-neutral-400 mb-3">Tips Styling</p>
      <p class="text-sm text-neutral-600 mb-4">
        Ingin tahu cara membangun tampilan hijab yang serba bisa dengan pilihan minimal?
      </p>
      <a
        href={url('/magazine/membangun-capsule-wardrobe-hijab')}
        class="text-xs tracking-widest uppercase text-neutral-600 border-b border-neutral-300 pb-0.5 hover:text-neutral-950 hover:border-neutral-950 transition-colors"
      >
        Panduan Capsule Wardrobe Hijab →
      </a>
    </div>
  </div>
</BaseLayout>
