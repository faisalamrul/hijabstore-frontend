---
import BaseLayout from '../../layouts/BaseLayout.astro';
import ProductCard from '../../components/ProductCard.astro';
import { getProductsByCategory } from '../../data/products';
import { url } from '../../lib/url';

const products = getProductsByCategory('pashmina');
const siteUrl = 'https://faisalamrul.github.io/hijabstore-frontend';

const collectionSchema = {
  '@context': 'https://schema.org',
  '@type': 'CollectionPage',
  name: 'Hijab Pashmina Premium — Koleksi Hara',
  description:
    'Koleksi hijab pashmina premium Hara. Voile, silk, rayon, dan linen — setiap bahan dipilih untuk kenyamanan maksimal dan tampilan yang flowing dan elegan.',
  url: `${siteUrl}/koleksi/pashmina`,
  breadcrumb: {
    '@type': 'BreadcrumbList',
    itemListElement: [
      { '@type': 'ListItem', position: 1, name: 'Home', item: siteUrl },
      { '@type': 'ListItem', position: 2, name: 'Koleksi Pashmina', item: `${siteUrl}/koleksi/pashmina` },
    ],
  },
  mainEntity: {
    '@type': 'ItemList',
    name: 'Hijab Pashmina Hara',
    itemListElement: products.map((p, i) => ({
      '@type': 'ListItem',
      position: i + 1,
      name: p.name,
      url: `${siteUrl}/products/${p.slug}`,
      image: p.images[0],
    })),
  },
};
---

<BaseLayout
  title="Hijab Pashmina Premium — Koleksi Hara"
  description="Koleksi hijab pashmina premium Hara. Voile, silk, rayon, dan linen — setiap bahan dipilih untuk kenyamanan maksimal dan tampilan yang flowing dan elegan."
>
  <Fragment slot="head">
    <script type="application/ld+json" set:html={JSON.stringify(collectionSchema)} />
  </Fragment>

  <div class="mx-auto max-w-7xl px-4 py-12 sm:px-6 lg:px-8 lg:py-20">
    <!-- Breadcrumb -->
    <nav class="mb-10 flex items-center gap-2 text-[10px] tracking-widest uppercase text-neutral-400">
      <a href={url('/')} class="hover:text-neutral-950 transition-colors">Home</a>
      <span>/</span>
      <span class="text-neutral-950">Pashmina</span>
    </nav>

    <!-- Header -->
    <div class="mb-12 max-w-2xl">
      <p class="text-[10px] tracking-[0.4em] uppercase text-neutral-400 mb-3">Koleksi</p>
      <h1 class="text-3xl sm:text-4xl font-light tracking-wide text-neutral-950 mb-6">
        Hijab Pashmina Premium
      </h1>
      <p class="text-base text-neutral-500 leading-relaxed">
        Pashmina adalah hijab persegi panjang yang menawarkan fleksibilitas tak tertandingi — satu lembar bisa menghasilkan puluhan gaya berbeda. Koleksi pashmina Hara menghadirkan pilihan bahan terbaik: voile yang ringan untuk hari-hari santai, silk yang mewah untuk acara spesial, rayon yang breathable untuk iklim tropis, dan linen yang timeless untuk tampilan editorial. Setiap pashmina berukuran standar 175×75 cm untuk pemakaian yang optimal.
      </p>
    </div>

    <!-- Product Grid -->
    <div class="grid grid-cols-2 gap-4 sm:gap-6 md:grid-cols-3">
      {products.map((product) => <ProductCard product={product} />)}
    </div>

    <!-- Cross-link to magazine -->
    <div class="mt-16 border-t border-neutral-100 pt-10">
      <p class="text-[10px] tracking-[0.4em] uppercase text-neutral-400 mb-3">Tutorial</p>
      <p class="text-sm text-neutral-600 mb-4">
        Pelajari 5 cara memakai pashmina dari casual hingga formal dalam panduan step-by-step kami.
      </p>
      <a
        href={url('/magazine/tutorial-hijab-pashmina-5-gaya')}
        class="text-xs tracking-widest uppercase text-neutral-600 border-b border-neutral-300 pb-0.5 hover:text-neutral-950 hover:border-neutral-950 transition-colors"
      >
        Tutorial 5 Gaya Pashmina →
      </a>
    </div>
  </div>
</BaseLayout>
